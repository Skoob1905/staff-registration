rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      );
    }

    function userRole() {
      return userDoc().data.role;
    }

    function userAgencyId() {
      return userDoc().data.agencyId;
    }

    function isSuper() {
      return isSignedIn() && userRole() == "super";
    }

    function isWorker() {
      return isSignedIn() && userRole() == "worker";
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function adminAssignedAgencyIds() {
      let ids = userDoc().data.assignedAgencyIds;
      return ids is list ? ids : [];
    }

    function adminHasAgency(agencyId) {
      return isAdmin() && (
        agencyId == userAgencyId() ||
        adminAssignedAgencyIds().hasAny([agencyId])
      );
    }

    // Unsigned contracts
    match /contracts/unsigned/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (
        (request.auth.uid == userId && (isClient() || isWorker())) ||
        isSuper()
      );
      allow write: if isSuper();
    }

    // Signed contracts
    match /contracts/signed/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (
        (request.auth.uid == userId && (isClient() || isWorker())) ||
        isSuper()
      );
      allow write: if isSignedIn() && (
        (request.auth.uid == userId && (isClient() || isWorker())) ||
        isSuper()
      );
    }

    // Payslips
    match /payslips/{userId}/{allPaths=**} {
      allow read: if isSignedIn()
      allow write: if isSuper();
    }

    // Staff uploads
    match /uploads/from_staff/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (
        (request.auth.uid == userId && (isClient() || isWorker())) ||
        isSuper()
      );
      allow write: if isSignedIn() && (
        (request.auth.uid == userId && (isClient() || isWorker())) ||
        isSuper()
      );
    }

    // CSV imports for agency client data
    match /agency_imports/{agencyId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // CSV imports for agency CSV uploads
    match /agencies/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // CSV imports for client CSV uploads
    match /clients/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // CSV imports for staff CSV uploads
    match /staff/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Signed contracts uploaded by admin against a client
    match /signed_contracts/{clientId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSuper();
    }

    // Timesheets uploaded by client users
    match /timesheets/{clientId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSuper();
    }

    // CSV imports for staff data
    match /staff_imports/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isSuper();
    }

    // CVs uploaded for staff members
    match /cvs/{staffId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSuper();
    }

    // Documents uploaded for staff members
    match /documents/{staffId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSuper();
    }

    // Bulk CSV uploads
    match /bulk-uploads/{allPaths=**} {
      allow read, write: if isSuper();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
