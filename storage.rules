rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(
        /databases/(default)/documents/users/$(request.auth.uid)
      );
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == "admin";
    }

    // Unsigned contracts assigned by admin to a staff member.
    match /contracts/unsigned/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // Signed contracts uploaded by staff (or admin if needed).
    match /contracts/signed/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Payslips uploaded by admin for staff, scoped per agency.
    // Path: payslips/{agencyId}/{userId}/{fileName}
    match /payslips/{agencyId}/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (
        (request.auth.uid == userId && userDoc().data.agencyId == agencyId) ||
        (isAdmin() && userDoc().data.agencyId == agencyId)
      );
      allow write: if isAdmin() && userDoc().data.agencyId == agencyId;
    }

    // Staff-initiated uploads back to agency.
    match /uploads/from_staff/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // CSV imports uploaded by admin for agency client data.
    // Auth check is enforced server-side by the cloud function; storage rules
    // avoid firestore.get() due to cross-service evaluation issues in this project.
    match /agency_imports/{agencyId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Signed contracts uploaded by admin against a client.
    match /signed_contracts/{clientId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Timesheets uploaded by client users.
    match /timesheets/{clientId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CSV imports uploaded by admin for staff data.
    // Auth check is enforced server-side by the cloud function; storage rules
    // avoid firestore.get() due to cross-service evaluation issues in this project.
    match /staff_imports/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // CVs uploaded by admin for staff members.
    match /cvs/{staffId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Bulk CSV uploads from the Upload page drag-and-drop zone.
    match /bulk-uploads/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
