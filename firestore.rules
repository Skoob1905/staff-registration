rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function userAgencyId() {
      return userDoc().data.agencyId;
    }

    function isSuper() {
      return isSignedIn() && userRole() == "super";
    }

    function isWorker() {
      return isSignedIn() && userRole() == "worker";
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function isClient() {
      return isSignedIn() && userRole() == "client";
    }

    function sameAgency(resourceAgencyId) {
      return isSignedIn() && resourceAgencyId == userAgencyId();
    }

    function adminAssignedAgencyIds() {
      let ids = userDoc().data.assignedAgencyIds;
      return ids is list ? ids : [];
    }

    function adminHasAgency(agencyId) {
      return isAdmin() && (
        agencyId == userAgencyId() ||
        adminAssignedAgencyIds().hasAny([agencyId])
      );
    }

    function clientHasAgency(agencyId) {
      let ids = userDoc().data.assignedAgencyIds;
      return isClient() && ids is list && agencyId in ids;
    }

    // Agencies
    match /agencies/{agencyId} {
      allow read: if isSignedIn() && (
        isSuper() ||
        adminHasAgency(agencyId) ||
        (isClient() || isWorker()) && (agencyId == userAgencyId() || clientHasAgency(agencyId))
      );
      allow list: if isClient();
      allow write: if isSuper();
    }

    // User profiles
    match /users/{uid} {
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        isSuper()
      );

      allow create: if isSuper() &&
        request.resource.data.agencyId == userAgencyId();

      allow update, delete: if isSuper();
    }

    // Unsigned contracts
    match /unsigned_contracts/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.targetUserId == request.auth.uid &&
         sameAgency(resource.data.agencyId) &&
         (isClient() || isWorker())) ||
        (isSuper() && sameAgency(resource.data.agencyId)) ||
        adminHasAgency(resource.data.agencyId)
      );

      allow create, update, delete: if isSuper() &&
        request.resource.data.agencyId == userAgencyId();
    }

    // Signed contracts
    match /signed_contracts/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         sameAgency(resource.data.agencyId) &&
         (isClient() || isWorker())) ||
        (isSuper() && sameAgency(resource.data.agencyId)) ||
        adminHasAgency(resource.data.agencyId)
      );

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.agencyId == userAgencyId() &&
        (isClient() || isWorker());

      allow update, delete: if isSuper() &&
        resource.data.agencyId == userAgencyId();
    }

    // Payslips
    match /payslips/{docId} {
      allow read: if isSignedIn();

      allow create, delete: if isSuper();

      allow update: if isSuper();

      allow update: if isSignedIn() &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.agencyId == resource.data.agencyId &&
        request.resource.data.fileName == resource.data.fileName &&
        request.resource.data.fileUrl == resource.data.fileUrl &&
        request.resource.data.sentBy == resource.data.sentBy &&
        request.resource.data.timestamp == resource.data.timestamp &&
        request.resource.data.hasDownloaded == true;
    }

    // Staff uploads
    match /staff_uploads/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         sameAgency(resource.data.agencyId) &&
         (isClient() || isWorker())) ||
        (isSuper() && sameAgency(resource.data.agencyId)) ||
        adminHasAgency(resource.data.agencyId)
      );

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.agencyId == userAgencyId() &&
        (isClient() || isWorker());

      allow update, delete: if isSuper() &&
        resource.data.agencyId == userAgencyId();
    }

    // CSV import history
    match /csv_imports/{docId} {
      allow read: if isSuper();
      allow write: if isSuper() && request.resource.data.agencyId == userAgencyId();
    }

    // Staff records imported via CSV
    match /staff/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuper();
    }

    // Clients collection (imported agencies)
    match /clients/{docId} {
      allow read: if isSignedIn() && (
        isSuper() ||
        adminHasAgency(resource.data.metadata.uploadedBy) ||
        (isClient() || isWorker()) && resource.data.metadata.uploadedBy == userAgencyId() ||
        resource.data.email == request.auth.token.email
      );
      allow write: if isSuper();
    }

    // Unregistered staff
    match /unregistered_staff/{docId} {
      allow read: if (
        (isSuper() && sameAgency(resource.data.agencyId)) ||
        adminHasAgency(resource.data.agencyId) ||
        (isSignedIn() && resource.data.uid == request.auth.uid)
      );
      allow create, update, delete: if isSuper() &&
        request.resource.data.agencyId == userAgencyId();
    }

    // Staff types
    match /staffType/{docId} {
      allow read: if isSuper();
      allow write: if isSuper();
    }

    // Tags
    match /tags/{docId} {
      allow read: if isSuper();
      allow write: if isSuper();
    }

    // Logins
    match /logins/{docId} {
      allow read: if isSuper();
      allow write: if isSuper();
    }

    // Password reset tokens — Admin SDK only, no client access
    match /passwordResets/{token} {
      allow read, write: if false;
    }
  }
}
