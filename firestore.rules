rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function userAgencyId() {
      return userDoc().data.agencyId;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == "admin";
    }

    function sameAgency(resourceAgencyId) {
      return isSignedIn() && resourceAgencyId == userAgencyId();
    }

    // Agencies
    match /agencies/{agencyId} {
      allow read: if isSignedIn() && agencyId == userAgencyId();
      allow write: if isAdmin() && agencyId == userAgencyId();
    }

    // User profiles
    match /users/{uid} {
      // User can read own profile; admin can read profiles in same agency
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        (isAdmin() && sameAgency(resource.data.agencyId))
      );

      // Admin manages users in own agency
      allow create: if isAdmin() &&
        request.resource.data.agencyId == userAgencyId();

      allow update, delete: if isAdmin() &&
        resource.data.agencyId == userAgencyId();
    }

    // Unsigned contracts (admin creates/manages, staff reads own pending)
    match /unsigned_contracts/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.targetUserId == request.auth.uid &&
         sameAgency(resource.data.agencyId)) ||
        (isAdmin() && sameAgency(resource.data.agencyId))
      );

      allow create, update, delete: if isAdmin() &&
        request.resource.data.agencyId == userAgencyId();
    }

    // Signed contracts (staff creates own; admin reads agency records)
    match /signed_contracts/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         sameAgency(resource.data.agencyId)) ||
        (isAdmin() && sameAgency(resource.data.agencyId))
      );

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.agencyId == userAgencyId();

      // Optional: admin can update/delete within agency
      allow update, delete: if isAdmin() &&
        resource.data.agencyId == userAgencyId();
    }

    // Payslips (admin writes, staff reads own)
    match /payslips/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         sameAgency(resource.data.agencyId)) ||
        (isAdmin() && sameAgency(resource.data.agencyId))
      );

      allow create, delete: if isAdmin() &&
        request.resource.data.agencyId == userAgencyId();

      // Admin can fully manage payslip docs in-agency.
      allow update: if isAdmin() && resource.data.agencyId == userAgencyId();

      // Staff can only mark their own payslip as downloaded.
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        resource.data.agencyId == userAgencyId() &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.agencyId == resource.data.agencyId &&
        request.resource.data.fileName == resource.data.fileName &&
        request.resource.data.fileUrl == resource.data.fileUrl &&
        request.resource.data.sentBy == resource.data.sentBy &&
        request.resource.data.timestamp == resource.data.timestamp &&
        request.resource.data.hasDownloaded == true;
    }

    // Manual staff uploads to agency
    match /staff_uploads/{docId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid &&
         sameAgency(resource.data.agencyId)) ||
        (isAdmin() && sameAgency(resource.data.agencyId))
      );

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.agencyId == userAgencyId();

      allow update, delete: if isAdmin() &&
        resource.data.agencyId == userAgencyId();
    }

    // Holds invited staff records before they complete registration and
    // are promoted into the users collection.
    match /unregistered_staff/{docId} {
      allow read: if (isAdmin() && sameAgency(resource.data.agencyId)) ||
        (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update, delete: if isAdmin() &&
        request.resource.data.agencyId == userAgencyId();
    }
  }
}
