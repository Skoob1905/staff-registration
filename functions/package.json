{
  "name": "functions",
  "scripts": {
    "lint": "eslint .",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "deploy:functions:dev": "firebase deploy --project development --only functions",
    "deploy:functions:prod": "firebase deploy --project production --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.1",
    "algoliasearch": "^5.53.0",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/nodemailer": "^8.0.1",
    "eslint": "^10.3.0",
    "firebase-functions-test": "^3.1.0",
    "globals": "^17.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "private": true
}
